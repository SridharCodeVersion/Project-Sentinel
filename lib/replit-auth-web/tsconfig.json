{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler"
  },
  "references": [
    { "path": "../../lib/api-client-react" }
  ]
}
